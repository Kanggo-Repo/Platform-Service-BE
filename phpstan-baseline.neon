parameters:
	ignoreErrors:
		-
			message: '#^Offset ''family_name'' on array\<mixed, mixed\> on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Http/Controllers/Api/V1/ProfileController.php

		-
			message: '#^Offset ''given_name'' on array\<mixed, mixed\> on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Http/Controllers/Api/V1/ProfileController.php

		-
			message: '#^Offset ''name'' on array\<mixed, mixed\> on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Http/Controllers/Api/V1/ProfileController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$permissions\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Middleware/EnsurePlatformOperatorRole.php

		-
			message: '#^Call to function is_string\(\) with string will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: app/Services/Identity/KeycloakAdminProvisioner.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$permissions\.$#'
			identifier: property.notFound
			count: 2
			path: app/Services/Identity/UserProjectionService.php

		-
			message: '#^If condition is always true\.$#'
			identifier: if.alwaysTrue
			count: 1
			path: app/Services/Identity/UserProjectionService.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$access_status\.$#'
			identifier: property.notFound
			count: 1
			path: app/Services/Navigation/NavigationResolver.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$service_code\.$#'
			identifier: property.notFound
			count: 2
			path: app/Services/Navigation/NavigationResolver.php

		-
			message: '#^Parameter \#1 \$callback of method Illuminate\\Database\\Eloquent\\Collection\<int,Illuminate\\Database\\Eloquent\\Model\>\:\:map\(\) contains unresolvable type\.$#'
			identifier: argument.unresolvableType
			count: 1
			path: app/Services/Navigation/NavigationResolver.php

		-
			message: '#^Parameter \#1 \$array \(list\<\(int\|string\)\>\) of array_values is already a list, call has no effect\.$#'
			identifier: arrayValues.list
			count: 1
			path: app/Support/Auth/PermissionRegistry.php

		-
			message: '#^Call to function is_string\(\) with string will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: app/Support/Observability/RequestCorrelation.php

		-
			message: '#^Method App\\Support\\Observability\\SentryEventContext\:\:beforeSend\(\) never returns null so it can be removed from the return type\.$#'
			identifier: return.unusedType
			count: 1
			path: app/Support/Observability/SentryEventContext.php

		-
			message: '#^Parameter \#1 \$user of method Sentry\\Event\:\:setUser\(\) expects Sentry\\UserDataBag\|null, array\<string, string\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Support/Observability/SentryEventContext.php
